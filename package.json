{
    "name": "tokenwave",
    "version": "1.1.9",
    "description": "All-in-one AI coding assistant — Claude Code & Codex in a single app",
    "engines": {
        "node": ">=20"
    },
    "main": "dist/main/index.js",
    "scripts": {
        "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
        "dev:main": "tsc -p tsconfig.main.json --watch",
        "dev:renderer": "vite dev",
        "build": "npm run build:main && npm run build:renderer",
        "build:main": "tsc -p tsconfig.main.json",
        "build:renderer": "vite build",
        "bundle-tools": "node scripts/bundle-tools.mjs",
        "package": "npm run build && npm run bundle-tools && electron-builder --win",
        "package:mac": "npm run build && npm run bundle-tools && electron-builder --mac --arm64",
        "start": "electron .",
        "rebuild-pty": "electron-rebuild -f -w node-pty"
    },
    "author": "TokenWave",
    "license": "MIT",
    "devDependencies": {
        "@electron/rebuild": "^3.7.2",
        "@types/node": "^20.11.0",
        "concurrently": "^8.2.2",
        "electron": "^33.4.11",
        "electron-builder": "^25.1.0",
        "electron-rebuild": "^3.2.9",
        "node-abi": "^4.31.0",
        "typescript": "^5.5.0",
        "vite": "^6.0.0"
    },
    "dependencies": {
        "@codemirror/lang-css": "^6.3.1",
        "@codemirror/lang-html": "^6.4.11",
        "@codemirror/lang-javascript": "^6.2.5",
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/lang-python": "^6.2.1",
        "@codemirror/theme-one-dark": "^6.1.3",
        "@xterm/addon-fit": "^0.10.0",
        "@xterm/addon-unicode11": "^0.8.0",
        "@xterm/addon-web-links": "^0.11.0",
        "@xterm/xterm": "^5.5.0",
        "codemirror": "^6.0.2",
        "electron-store": "^8.2.0",
        "node-pty": "^1.0.0",
        "qrcode": "^1.5.4"
    },
    "build": {
        "appId": "com.tokenwave.app",
        "productName": "TokenWave",
        "directories": {
            "output": "release"
        },
        "win": {
            "icon": "resources/icon.ico",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "mac": {
            "icon": "resources/icon.icns",
            "category": "public.app-category.developer-tools",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64",
                        "x64"
                    ]
                }
            ]
        },
        "dmg": {
            "artifactName": "${productName}-${version}-${arch}.${ext}",
            "window": {
                "width": 540,
                "height": 400
            },
            "contents": [
                {
                    "x": 140,
                    "y": 170,
                    "type": "file"
                },
                {
                    "x": 400,
                    "y": 170,
                    "type": "link",
                    "path": "/Applications"
                },
                {
                    "x": 270,
                    "y": 330,
                    "type": "file",
                    "path": "resources/dmg/安装说明-必读.txt"
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "deleteAppDataOnUninstall": true
        },
        "asar": true,
        "asarUnpack": [
            "resources/bundled-tools/**",
            "node_modules/node-pty/**"
        ],
        "extraResources": [
            {
                "from": "resources/bundled-tools",
                "to": "bundled-tools"
            }
        ],
        "files": [
            "dist/**/*",
            "resources/**/*",
            "!resources/bundled-tools/*/node_modules/.cache/**"
        ]
    }
}
